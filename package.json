{
  "name": "25mordad-social-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "dev:remote": "wrangler dev --remote",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create social-app-db",
    "db:migrate": "wrangler d1 execute social-app-db --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute social-app-db --remote --file=./schema.sql",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@cloudflare/workers-types": "^4.20250525.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.7",
    "wrangler": "^3.99.0"
  }
}
